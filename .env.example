# Supabase（本番・ステージング共通）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database
# ローカル開発: docker-compose.yml の db サービスに自動設定
# 本番: Supabase の接続文字列を設定
DATABASE_URL=postgresql://postgres:postgres@db:5432/gochispace

# ホットペッパーAPI
HOTPEPPER_API_KEY=your-hotpepper-api-key

# App
PORT=3000
NODE_ENV=development
